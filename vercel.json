// Vercel deployment configuration
// This file configures how the portfolio is deployed on Vercel

{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "framework": "html",
  "env": [
    {
      "key": "PORTFOLIO_OWNER_ADDRESS",
      "description": "Your Ethereum wallet address",
      "value": ""
    },
    {
      "key": "CONTRACT_ADDRESS",
      "description": "Deployed contract address",
      "value": ""
    }
  ],
  "redirects": [
    {
      "source": "/old-portfolio",
      "destination": "/"
    }
  ],
  "rewrites": [],
  "functions": {},
  "cleanUrls": true
}

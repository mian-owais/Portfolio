# Environment Variables - Copy to .env and fill in your values

# Portfolio Information
PORTFOLIO_OWNER_ADDRESS=0x0000000000000000000000000000000000000000
PORTFOLIO_OWNER_PRIVATE_KEY=your_private_key_here

# Network Configuration
ETHEREUM_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/your-api-key
SEPOLIA_RPC_URL=https://eth-sepolia.alchemyapi.io/v2/your-api-key
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key

# Block Explorers
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Smart Contract Addresses (after deployment)
PORTFOLIO_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# IPFS
IPFS_API_URL=https://api.pinata.cloud
IPFS_API_KEY=your_pinata_api_key
IPFS_API_SECRET=your_pinata_api_secret

# GitHub Pages Deployment
GITHUB_USERNAME=yourusername
GITHUB_REPO=portfolio
GITHUB_TOKEN=your_github_token

# Vercel Deployment (Alternative)
VERCEL_TOKEN=your_vercel_token
VERCEL_PROJECT_ID=your_project_id

# Web3 Configuration
WEB3_PROVIDER=MetaMask
NETWORK=sepolia

# Email Configuration (for contact form)
EMAIL_SERVICE=gmail
EMAIL_ADDRESS=your.email@gmail.com
EMAIL_PASSWORD=your_app_password

# Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
SENTRY_DSN=

# Feature Flags
ENABLE_BLOCKCHAIN_FEATURES=true
ENABLE_ANALYTICS=true
ENABLE_CONTACT_FORM=true

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Security
ENABLE_CSP_HEADERS=true
ENABLE_HTTPS_ONLY=true

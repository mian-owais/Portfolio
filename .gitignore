# .gitignore - Ignore files and directories

# Dependencies
node_modules/
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
out/
contracts/build/
artifacts/
cache/

# Contract deployment artifacts
.openzeppelin/
deployments/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Hardhat
hardhat-cache/

# IPFS
.ipfs/

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
*.bak

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db

# Analytics
analytics/

# Security
*.pem
*.key
*.cert

# IDE specific
*.code-workspace
.vscode-test
.history/

# CI/CD
.github/workflows/logs/

# Secrets
secrets/
passcodes.txt
credentials.json

# Database
*.db
*.sqlite
data/

# Archive files
*.zip
*.tar
*.tar.gz
*.7z
*.rar
